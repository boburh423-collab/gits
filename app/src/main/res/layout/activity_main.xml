<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000d07">

    <!-- Progress bar (yuqorida) -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_alignParentTop="true"
        android:progressTint="#10b981"
        android:progressBackgroundTint="#021a10"
        android:max="100"
        android:visibility="gone"
        android:indeterminate="false"/>

    <!-- WebView -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/progressBar"
        android:background="#000d07"
        android:visibility="visible"/>

    <!-- Loading ekrani -->
    <RelativeLayout
        android:id="@+id/loadingLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000d07"
        android:gravity="center"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_centerInParent="true">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminateTint="#10b981"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yuklanmoqda..."
                android:textColor="#4b7a62"
                android:textSize="14sp"
                android:layout_marginTop="16dp"/>

        </LinearLayout>

    </RelativeLayout>

    <!-- Offline ekrani -->
    <LinearLayout
        android:id="@+id/offlineLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="#000d07"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📡"
            android:textSize="64sp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Internet yo'q"
            android:textColor="#a7f3d0"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Internet ulanishini tekshiring va qayta urinib ko'ring"
            android:textColor="#4b7a62"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/retryBtn"
            android:layout_width="180dp"
            android:layout_height="48dp"
            android:text="Qayta urinish"
            android:textColor="#000d07"
            android:textStyle="bold"
            android:background="@drawable/btn_bg"
            android:textSize="15sp"/>

    </LinearLayout>

</RelativeLayout>
